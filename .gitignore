# Translation output files
pdf2zh_files/

# Logs
logs/

# Python cache
__pycache__/
*.pyc
*.pyo

# User config
config/user.json

# Embedded Python runtime (too large for git)
core/runtime/
core/site-packages/

# Only track our custom pdf2zh source (unignore)
!core/site-packages/pdf2zh/

# But still ignore pycache inside pdf2zh
core/site-packages/pdf2zh/__pycache__/

# Binary / large files
*.exe
*.zip
*.pyd
*.dll
*.so
*.dylib
*.onnx
cache/

